# Copy this file to `.env.local` (which is git-ignored) and fill in your values.
# Used by scripts/s2-webdav-probe.mjs and, later, local integration tests.
#
# Infomaniak kDrive WebDAV:
#   - URL format: https://<kdrive-id>.connect.kdrive.infomaniak.com/
#     (find it in kDrive > settings; some setups use https://connect.drive.infomaniak.com/)
#   - USER is your Infomaniak email.
#   - PASS must be an APP-SPECIFIC password generated in your Infomaniak account
#     (manager.infomaniak.com > account > security > application passwords).
#     The kDrive WebDAV endpoint does NOT accept your normal login password.

SELFSYNC_WEBDAV_URL=https://your-kdrive-id.connect.kdrive.infomaniak.com/
SELFSYNC_WEBDAV_USER=you@example.com
SELFSYNC_WEBDAV_PASS=your-app-specific-password

# Self-hosted Apache mod_dav (docker compose up -d webdav) — enables
# tests/webdav-apache.spec.ts (skipped otherwise).
SELFSYNC_APACHEDAV_URL=http://localhost:8080
SELFSYNC_APACHEDAV_USER=selfsync
SELFSYNC_APACHEDAV_PASS=change-me-please
